<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- En-tête -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nouveau contact"
            android:textColor="@color/color_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Remplissez les informations ci-dessous"
            android:textColor="@color/color_text_muted"
            android:textSize="14sp" />

        <!-- Barre de progression -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="5"
                android:progress="0"
                android:progressDrawable="@drawable/progress_custom" />

            <TextView
                android:id="@+id/tvProgressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0 / 5"
                android:textColor="@color/color_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SECTION IDENTITÉ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="IDENTITÉ"
            android:textColor="@color/color_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Champ Nom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_purple" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-36dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="👤"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom &amp; Prénom *"
                    android:textColor="@color/color_text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/nom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Ex: LACHGAR Mohamed"
                    android:inputType="textPersonName"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/validNom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="✓"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/errNom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="4dp"
            android:text="Minimum 3 caractères requis"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- SECTION COORDONNÉES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="COORDONNÉES"
            android:textColor="@color/color_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Champ Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-36dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="✉️"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email *"
                    android:textColor="@color/color_text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="contact@domaine.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/validEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="✓"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/errEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="4dp"
            android:text="Email invalide"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Champ Téléphone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-36dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="📞"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Téléphone"
                    android:textColor="@color/color_text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="+212 600 000 000"
                    android:inputType="phone"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/validPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="✓"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/errPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="4dp"
            android:text="Format invalide"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- SECTION LOCALISATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="LOCALISATION"
            android:textColor="@color/color_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Champ Adresse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_coral" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-36dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="📍"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adresse"
                    android:textColor="@color/color_text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/adresse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Rue, quartier..."
                    android:inputType="textPostalAddress"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/validAdresse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="✓"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Champ Ville -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_amber" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-36dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:text="🏙️"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ville"
                    android:textColor="@color/color_text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/ville"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Ex: Casablanca"
                    android:inputType="text"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/validVille"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="✓"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEnvoyer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/color_primary"
            android:enabled="false"
            android:text="ENVOYER LE FORMULAIRE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>